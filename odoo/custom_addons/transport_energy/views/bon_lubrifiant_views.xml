<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ VUE FORMULAIRE ═══ -->
    <record id="view_bon_lubrifiant_form" model="ir.ui.view">
        <field name="name">transport.bon.lubrifiant.form</field>
        <field name="model">transport.bon.lubrifiant</field>
        <field name="arch" type="xml">
            <form string="Bon de Ravitaillement Lubrifiant">
                <header>
                    <button name="action_confirmer"
                            string="Confirmer"
                            type="object"
                            class="btn-primary"
                            invisible="statut != 'brouillon'"/>
                    <button name="action_valider"
                            string="Valider"
                            type="object"
                            class="btn-success"
                            invisible="statut != 'confirme'"/>
                    <button name="action_annuler"
                            string="Annuler"
                            type="object"
                            invisible="statut in ['valide', 'annule']"/>
                    <button name="action_brouillon"
                            string="Remettre en brouillon"
                            type="object"
                            invisible="statut != 'annule'"/>
                    <field name="statut" widget="statusbar"
                           statusbar_visible="brouillon,confirme,valide"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Informations générales">
                            <field name="date"/>
                            <field name="atelier"/>
                            <field name="agence"/>
                        </group>
                        <group string="Véhicule">
                            <field name="vehicule_id"/>
                            <field name="code_service"/>
                            <field name="code_chauffeur"/>
                            <field name="nom_chauffeur"/>
                        </group>
                    </group>

                    <group>
                        <group string="Kilométrage">
                            <field name="kilometrage"/>
                            <field name="dernier_vidange_km"/>
                            <field name="prochain_vidange_km"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Lignes lubrifiants">
                            <field name="ligne_ids">
                                <tree editable="bottom">
                                    <field name="type_operation"/>
                                    <field name="type_lubrifiant_id"
                                           domain="[('category', '=', 'lubrifiant')]"
                                           options="{'no_create': True, 'no_create_edit': True}"/>
                                    <field name="quantite_videe"
                                           optional="show"
                                           invisible="type_operation != 'vidange'"/>
                                    <field name="quantite"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="quantite_totale"
                                       string="Total ajouté (L)"/>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes"
                                   placeholder="Observations..."/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ VUE LISTE ═══ -->
    <record id="view_bon_lubrifiant_tree" model="ir.ui.view">
        <field name="name">transport.bon.lubrifiant.tree</field>
        <field name="model">transport.bon.lubrifiant</field>
        <field name="arch" type="xml">
            <tree string="Bons Lubrifiants"
                  decoration-success="statut == 'valide'"
                  decoration-warning="statut == 'confirme'"
                  decoration-muted="statut == 'annule'">
                <field name="name"/>
                <field name="date"/>
                <field name="atelier"/>
                <field name="vehicule_id"/>
                <field name="code_service"/>
                <field name="kilometrage"/>
                <field name="quantite_totale"/>
                <field name="statut"/>
            </tree>
        </field>
    </record>

    <!-- ═══ VUE RECHERCHE ═══ -->
    <record id="view_bon_lubrifiant_search" model="ir.ui.view">
        <field name="name">transport.bon.lubrifiant.search</field>
        <field name="model">transport.bon.lubrifiant</field>
        <field name="arch" type="xml">
            <search string="Recherche">
                <field name="name"/>
                <field name="vehicule_id"/>
                <field name="atelier"/>
                <filter name="valide" string="Validés"
                        domain="[('statut','=','valide')]"/>
                <filter name="brouillon" string="Brouillons"
                        domain="[('statut','=','brouillon')]"/>
                <separator/>
                <filter name="aujourd_hui" string="Aujourd'hui"
                        domain="[('date','=', context_today().strftime('%Y-%m-%d'))]"/>
                <group string="Regrouper par">
                    <filter name="groupe_vehicule" string="Véhicule"
                            context="{'group_by': 'vehicule_id'}"/>
                    <filter name="groupe_atelier" string="Atelier"
                            context="{'group_by': 'atelier'}"/>
                    <filter name="groupe_date" string="Date"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ ACTION ═══ -->
    <record id="action_bon_lubrifiant" model="ir.actions.act_window">
        <field name="name">Bons Lubrifiants</field>
        <field name="res_model">transport.bon.lubrifiant</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_bon_lubrifiant_search"/>
    </record>

    <!-- ═══ MENU ═══ -->
    <menuitem id="menu_lubrifiants"
              name="🛢️ Lubrifiants"
              parent="menu_transport_energy_root"
              sequence="20"/>

    <menuitem id="menu_bon_lubrifiant"
              name="Bons Lubrifiants"
              parent="menu_lubrifiants"
              action="action_bon_lubrifiant"
              sequence="10"/>

</odoo>