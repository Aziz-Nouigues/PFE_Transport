<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ VUE FORMULAIRE ═══ -->
    <record id="view_jaugeage_form" model="ir.ui.view">
        <field name="name">transport.jaugeage.form</field>
        <field name="model">transport.jaugeage</field>
        <field name="arch" type="xml">
            <form string="Jaugeage des cuves">
                <header>
                    <button name="action_confirmer"
                            string="Confirmer"
                            type="object"
                            class="btn-primary"
                            invisible="statut != 'brouillon'"/>
                    <button name="action_approuver"
                            string="Approuver"
                            type="object"
                            class="btn-success"
                            invisible="statut != 'confirme'"/>
                    <button name="action_annuler"
                            string="Annuler"
                            type="object"
                            invisible="statut in ['approuve','annule']"/>
                    <button name="action_brouillon"
                            string="Remettre en brouillon"
                            type="object"
                            invisible="statut != 'annule'"/>
                    <field name="statut" widget="statusbar"
                           statusbar_visible="brouillon,confirme,approuve"/>
                </header>

                <sheet>
                    <!-- Badge alerte -->
                    <div class="oe_button_box" name="button_box">
                        <field name="niveau_alerte" widget="badge"
                               decoration-success="niveau_alerte == 'normal'"
                               decoration-warning="niveau_alerte == 'attention'"
                               decoration-danger="niveau_alerte == 'critique'"/>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Informations">
                            <field name="date"/>
                            <field name="responsable"/>
                            <field name="station_id"/>
                        </group>
                        <group string="Niveaux">
                            <field name="stock_theorique"/>
                            <field name="niveau_mesure"/>
                            <field name="ecart"/>
                            <field name="ecart_pourcentage"/>
                        </group>
                    </group>

                    <!-- Justification visible si écart > 1% -->
                    <group string="Justification &amp; Ajustement"
                           invisible="niveau_alerte == 'normal'">
                        <field name="ajustement_stock"/>
                        <field name="justification"
                               placeholder="Expliquer l'écart..."/>
                    </group>

                    <field name="notes" placeholder="Notes..."/>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ VUE LISTE ═══ -->
    <record id="view_jaugeage_tree" model="ir.ui.view">
        <field name="name">transport.jaugeage.tree</field>
        <field name="model">transport.jaugeage</field>
        <field name="arch" type="xml">
            <tree string="Jaugeages"
                  decoration-danger="niveau_alerte == 'critique'"
                  decoration-warning="niveau_alerte == 'attention'"
                  decoration-success="niveau_alerte == 'normal'">
                <field name="name"/>
                <field name="date"/>
                <field name="station_id"/>
                <field name="responsable"/>
                <field name="stock_theorique"/>
                <field name="niveau_mesure"/>
                <field name="ecart"/>
                <field name="ecart_pourcentage"/>
                <field name="niveau_alerte"/>
                <field name="statut"/>
            </tree>
        </field>
    </record>

    <!-- ═══ VUE RECHERCHE ═══ -->
    <record id="view_jaugeage_search" model="ir.ui.view">
        <field name="name">transport.jaugeage.search</field>
        <field name="model">transport.jaugeage</field>
        <field name="arch" type="xml">
            <search string="Recherche">
                <field name="name"/>
                <field name="station_id"/>
                <field name="responsable"/>
                <filter name="critique" string="🔴 Critique"
                        domain="[('niveau_alerte','=','critique')]"/>
                <filter name="attention" string="⚠️ Attention"
                        domain="[('niveau_alerte','=','attention')]"/>
                <filter name="normal" string="✅ Normal"
                        domain="[('niveau_alerte','=','normal')]"/>
                <separator/>
                <filter name="approuve" string="Approuvés"
                        domain="[('statut','=','approuve')]"/>
                <group string="Regrouper par">
                    <filter name="groupe_station" string="Station"
                            context="{'group_by': 'station_id'}"/>
                    <filter name="groupe_alerte" string="Niveau alerte"
                            context="{'group_by': 'niveau_alerte'}"/>
                    <filter name="groupe_date" string="Date"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ ACTION ═══ -->
    <record id="action_jaugeage" model="ir.actions.act_window">
        <field name="name">Jaugeages</field>
        <field name="res_model">transport.jaugeage</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_jaugeage_search"/>
    </record>

    <!-- ═══ MENU ═══ -->
    <menuitem id="menu_jaugeage_root"
              name="📈 Jaugeage"
              parent="menu_transport_energy_root"
              sequence="40"/>

    <menuitem id="menu_jaugeage"
              name="Opérations de jaugeage"
              parent="menu_jaugeage_root"
              action="action_jaugeage"
              sequence="10"/>

</odoo>
