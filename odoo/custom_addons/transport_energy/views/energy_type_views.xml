<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue Liste -->
    <record id="view_energy_type_list" model="ir.ui.view">
        <field name="name">transport.energy.type.list</field>
        <field name="model">transport.energy.type</field>
        <field name="arch" type="xml">
            <tree string="Types d'énergie">
                <field name="name"/>
                <field name="category"/>
                <field name="unite"/>
                <field name="actif"/>
            </tree>
        </field>
    </record>

    <!-- Vue Formulaire -->
    <record id="view_energy_type_form" model="ir.ui.view">
        <field name="name">transport.energy.type.form</field>
        <field name="model">transport.energy.type</field>
        <field name="arch" type="xml">
            <form string="Type d'énergie">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="unite"/>
                        <field name="actif"/>
                    </group>
                    <field name="notes"
                           placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_energy_type"
            model="ir.actions.act_window">
        <field name="name">Types d'énergie</field>
        <field name="res_model">transport.energy.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu principal -->
    <menuitem
        id="menu_transport_energy_root"
        name="Énergie Transport"
        sequence="50"/>

    <!-- Sous-menu Configuration -->
    <menuitem
        id="menu_energy_config"
        name="Configuration"
        parent="menu_transport_energy_root"
        sequence="90"/>

    <!-- Sous-menu Types d'énergie -->
    <menuitem
        id="menu_energy_type"
        name="Types d'énergie"
        parent="menu_energy_config"
        action="action_energy_type"
        sequence="10"/>

</odoo>