<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extension de la vue formulaire fleet.vehicle -->
    <record id="view_fleet_vehicle_transport_form" model="ir.ui.view">
        <field name="name">fleet.vehicle.transport.form</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">

            <!-- Ajouter un nouvel onglet "Transport" -->
            <xpath expr="//notebook" position="inside">
                <page string="🚌 Transport" name="transport_info">

                    <group>
                        <group string="Classification">
                            <field name="bus_type"/>
                            <field name="activity_type"/>
                            <field name="internal_code"/>
                            <field name="service_code"/>
                        </group>
                        <group string="Agence">
                            <field name="transport_agency"/>
                            <field name="agency_code"/>
                            <field name="fuel_station_id"/>
                        </group>
                    </group>

                    <group>
                        <group string="Consommation Théorique">
                            <field name="theoretical_fuel_consumption"/>
                            <field name="theoretical_oil_consumption"/>
                            <field name="fuel_tank_capacity"/>
                        </group>
                        <group string="Compteur Kilométrique">
                            <field name="odometer_status"/>
                            <field name="odometer_replacement_date"
                                   invisible="odometer_status == 'ok'"/>
                            <field name="odometer_old_value"
                                   invisible="odometer_status == 'ok'"/>
                        </group>
                    </group>

                </page>
            </xpath>

        </field>
    </record>

</odoo>