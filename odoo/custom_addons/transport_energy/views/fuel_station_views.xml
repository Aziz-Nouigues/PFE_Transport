<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ VUE FORMULAIRE ═══ -->
    <record id="view_fuel_station_form" model="ir.ui.view">
        <field name="name">transport.fuel.station.form</field>
        <field name="model">transport.fuel.station</field>
        <field name="arch" type="xml">
            <form string="Station de pompage">
                <sheet>
                    <group>
                        <group string="Identification">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="pump_number"/>
                            <field name="station_type"/>
                            <field name="active"/>
                        </group>
                        <group string="Localisation">
                            <field name="agency_id"/>
                            <field name="address"/>
                        </group>
                    </group>
                    <group>
                        <group string="Carburant et Stock">
                            <field name="fuel_type_id"/>
                            <field name="capacity"/>
                            <field name="current_stock"/>
                            <field name="stock_percentage"/>
                            <field name="min_stock_alert"/>
                        </group>
                        <group string="Compteur Pompe">
                            <field name="pump_counter_start"/>
                            <field name="pump_counter_current"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ VUE LISTE (tree) ═══ -->
    <record id="view_fuel_station_tree" model="ir.ui.view">
        <field name="name">transport.fuel.station.tree</field>
        <field name="model">transport.fuel.station</field>
        <field name="arch" type="xml">
            <tree string="Stations de pompage"
                  decoration-danger="stock_status == 'critical'"
                  decoration-warning="stock_status == 'low'">
                <field name="name"/>
                <field name="code"/>
                <field name="pump_number"/>
                <field name="station_type"/>
                <field name="agency_id"/>
                <field name="fuel_type_id"/>
                <field name="current_stock"/>
                <field name="capacity"/>
                <field name="stock_percentage"/>
                <field name="stock_status"/>
            </tree>
        </field>
    </record>

    <!-- ═══ VUE RECHERCHE ═══ -->
    <record id="view_fuel_station_search" model="ir.ui.view">
        <field name="name">transport.fuel.station.search</field>
        <field name="model">transport.fuel.station</field>
        <field name="arch" type="xml">
            <search string="Recherche">
                <field name="name"/>
                <field name="code"/>
                <field name="agency_id"/>
                <filter name="internal" string="Internes"
                        domain="[('station_type','=','internal')]"/>
                <filter name="external" string="Externes"
                        domain="[('station_type','=','external')]"/>
                <separator/>
                <filter name="low_stock" string="Stock bas"
                        domain="[('stock_status','in',['low','critical'])]"/>
                <group string="Regrouper par">
                    <filter name="group_agency" string="Agence"
                            context="{'group_by': 'agency_id'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'station_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ ACTION ═══ -->
    <record id="action_fuel_station" model="ir.actions.act_window">
        <field name="name">Stations de pompage</field>
        <field name="res_model">transport.fuel.station</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_fuel_station_search"/>
    </record>

    <!-- ═══ MENU ═══ -->
    <menuitem id="menu_fuel_station"
              name="Stations de pompage"
              parent="menu_energy_config"
              action="action_fuel_station"
              sequence="20"/>

</odoo>