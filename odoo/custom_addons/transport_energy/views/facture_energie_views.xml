<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ VUE FORMULAIRE ═══ -->
    <record id="view_facture_energie_form" model="ir.ui.view">
        <field name="name">transport.facture.energie.form</field>
        <field name="model">transport.facture.energie</field>
        <field name="arch" type="xml">
            <form string="Facture Énergie STEG/SONEDE">
                <header>
                    <button name="action_payer"
                            string="Marquer Payée"
                            type="object"
                            class="btn-success"
                            invisible="statut != 'saisie'"/>
                    <button name="action_annuler"
                            string="Annuler"
                            type="object"
                            invisible="statut == 'annulee'"/>
                    <field name="statut" widget="statusbar"
                           statusbar_visible="saisie,payee"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Informations facture">
                            <field name="type_facture"/>
                            <field name="date_reception"/>
                            <field name="numero_compteur"/>
                            <field name="adresse"/>
                        </group>
                        <group string="Site">
                            <field name="site"/>
                        </group>
                    </group>

                    <group>
                        <group string="Période de consommation">
                            <field name="date_debut_periode"/>
                            <field name="date_fin_periode"/>
                        </group>
                        <group string="Consommation">
                            <field name="quantite_consommee"/>
                            <field name="unite_mesure"/>
                            <field name="montant"/>
                        </group>
                    </group>

                    <!-- Comparaison N-1 -->
                    <group string="📊 Comparaison avec N-1">
                        <group>
                            <field name="consommation_n1"/>
                            <field name="montant_n1"/>
                        </group>
                        <group>
                            <field name="ecart_consommation"/>
                            <field name="ecart_pourcentage"/>
                        </group>
                    </group>

                    <field name="notes" placeholder="Notes..."/>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ VUE LISTE ═══ -->
    <record id="view_facture_energie_tree" model="ir.ui.view">
        <field name="name">transport.facture.energie.tree</field>
        <field name="model">transport.facture.energie</field>
        <field name="arch" type="xml">
            <tree string="Factures Énergie"
                  decoration-success="statut == 'payee'"
                  decoration-muted="statut == 'annulee'">
                <field name="name"/>
                <field name="type_facture"/>
                <field name="site"/>
                <field name="numero_compteur"/>
                <field name="date_debut_periode"/>
                <field name="date_fin_periode"/>
                <field name="quantite_consommee"/>
                <field name="unite_mesure"/>
                <field name="montant"/>
                <field name="ecart_pourcentage"/>
                <field name="statut"/>
            </tree>
        </field>
    </record>

    <!-- ═══ VUE RECHERCHE ═══ -->
    <record id="view_facture_energie_search" model="ir.ui.view">
        <field name="name">transport.facture.energie.search</field>
        <field name="model">transport.facture.energie</field>
        <field name="arch" type="xml">
            <search string="Recherche">
                <field name="name"/>
                <field name="site"/>
                <field name="numero_compteur"/>
                <filter name="steg" string="⚡ STEG"
                        domain="[('type_facture','=','steg')]"/>
                <filter name="sonede" string="💧 SONEDE"
                        domain="[('type_facture','=','sonede')]"/>
                <separator/>
                <filter name="saisie" string="Non payées"
                        domain="[('statut','=','saisie')]"/>
                <filter name="payee" string="Payées"
                        domain="[('statut','=','payee')]"/>
                <group string="Regrouper par">
                    <filter name="groupe_site" string="Site"
                            context="{'group_by': 'site'}"/>
                    <filter name="groupe_type" string="Type"
                            context="{'group_by': 'type_facture'}"/>
                    <filter name="groupe_date" string="Période"
                            context="{'group_by': 'date_debut_periode:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ ACTIONS ═══ -->
    <record id="action_facture_steg" model="ir.actions.act_window">
        <field name="name">Factures STEG</field>
        <field name="res_model">transport.facture.energie</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('type_facture','=','steg')]</field>
        <field name="context">{'default_type_facture': 'steg'}</field>
    </record>

    <record id="action_facture_sonede" model="ir.actions.act_window">
        <field name="name">Factures SONEDE</field>
        <field name="res_model">transport.facture.energie</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('type_facture','=','sonede')]</field>
        <field name="context">{'default_type_facture': 'sonede'}</field>
    </record>

    <!-- ═══ MENUS ═══ -->
    <menuitem id="menu_energie_eau"
              name="Facture"
              parent="menu_transport_energy_root"
              sequence="30"/>

    <menuitem id="menu_facture_steg"
              name="⚡ Factures STEG"
              parent="menu_energie_eau"
              action="action_facture_steg"
              sequence="10"/>

    <menuitem id="menu_facture_sonede"
              name="💧 Factures SONEDE"
              parent="menu_energie_eau"
              action="action_facture_sonede"
              sequence="20"/>

</odoo>