<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ VUE WIZARD ═══ -->
    <record id="view_wizard_rapport_form" model="ir.ui.view">
        <field name="name">transport.wizard.rapport.form</field>
        <field name="model">transport.wizard.rapport</field>
        <field name="arch" type="xml">
            <form string="Générer un Rapport">
                <group>
                    <group string="Type de rapport">
                        <field name="type_rapport" widget="radio"/>
                        <field name="seuil_excessif"
                               invisible="type_rapport != 'excessif'"/>
                    </group>
                    <group string="Filtres">
                        <field name="date_debut"/>
                        <field name="date_fin"/>
                        <field name="station_id"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generer_rapport"
                            string="📊 Générer le Rapport"
                            type="object"
                            class="btn-primary"/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ═══ ACTION WIZARD ═══ -->
    <record id="action_wizard_rapport" model="ir.actions.act_window">
        <field name="name">Rapports de Consommation</field>
        <field name="res_model">transport.wizard.rapport</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ═══ MENU ═══ -->
    <menuitem id="menu_rapports_root"
              name="📊 Rapports"
              parent="menu_transport_energy_root"
              sequence="50"/>

    <menuitem id="menu_rapport_consommation"
              name="Consommation Carburant"
              parent="menu_rapports_root"
              action="action_wizard_rapport"
              sequence="10"/>

</odoo>
