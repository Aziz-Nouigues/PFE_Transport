                        <div style="text-align:center; margin-bottom:20px;">
                            <h2 style="color:#C55A11; font-size:18px;">
                                بطاقة التزود بالوقود الخارجي
                            </h2>
                            <h3 style="color:#C55A11; font-size:14px;">
                                Bon de Gasoil Externe (BGE)
                            </h3>
                        </div>

                        <!-- ── INFORMATIONS BON ── -->
                        <table style="width:100%; margin-bottom:15px;
                                      border-collapse:collapse;
                                      border:1px solid #C55A11;">
                            <tr style="background-color:#FCE4D6;">
                                <td style="padding:6px; width:33%;">
                                    <strong>N° Bon :</strong>
                                    <t t-esc="bon.name"/>
                                </td>
                                <td style="padding:6px; width:33%;">
                                    <strong>Date :</strong>
                                    <t t-esc="bon.date"/>
                                </td>
                                <td style="padding:6px; width:33%;">
                                    <strong>Station :</strong>
                                    <t t-esc="bon.station_id.name or ''"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:6px;">
                                    <strong>Type carburant :</strong>
                                    <t t-esc="bon.fuel_type_id.name or ''"/>
