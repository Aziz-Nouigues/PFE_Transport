                                    <t t-esc="'%02d:%02d' % (int(bon.time_start), int((bon.time_start % 1) * 60))"/>
                                </td>
                                <td style="padding:6px;">
                                    <strong>Heure fin :</strong>
                                    <t t-esc="'%02d:%02d' % (int(bon.time_end), int((bon.time_end % 1) * 60))"/>
                                </td>
                            </tr>
                        </table>

                        <!-- ── LIGNES ── -->
                        <table style="width:100%; border-collapse:collapse; font-size:11px;">
                            <thead>
                                <tr style="background-color:#C55A11; color:white;">
                                    <th style="border:1px solid #ccc; padding:6px; text-align:center;">
                                        المصلحة<br/>Service
                                    </th>
                                    <th style="border:1px solid #ccc; padding:6px; text-align:center;">
                                        العربة<br/>Bus N°
                                    </th>
                                    <th style="border:1px solid #ccc; padding:6px; text-align:center;">
                                        التوقيت<br/>Heure
                                    </th>
                                    <th style="border:1px solid #ccc; padding:6px; text-align:center;">
                                        عداد العربة<br/>Compteur
                                    </th>
                                    <th style="border:1px solid #ccc; padding:6px; text-align:center;">
                                        الكمية<br/>Quantité (L)
                                    </th>
                                    <th style="border:1px solid #ccc; padding:6px; text-align:center;">
                                        إسم السائق<br/>Chauffeur
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="bon.line_ids" t-as="ligne">
                                    <tr>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">
                                            <t t-esc="ligne.service_code or ''"/>
                                        </td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">
                                            <t t-esc="ligne.vehicle_id.name or ''"/>
                                        </td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">
                                            <t t-esc="'%02d:%02d' % (int(ligne.time), int((ligne.time % 1) * 60))"/>
                                        </td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">
                                            <t t-esc="int(ligne.odometer_value)"/>
                                        </td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center; font-weight:bold;">
                                            <t t-esc="ligne.quantity"/>
                                        </td>
                                        <td style="border:1px solid #ccc; padding:5px; text-align:center;">
                                            <t t-esc="ligne.driver_name or ''"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="background-color:#FCE4D6; font-weight:bold;">
                                    <td colspan="4" style="border:1px solid #ccc; padding:6px; text-align:right;">
                                        الجملة / Total :
                                    </td>
                                    <td style="border:1px solid #ccc; padding:6px; text-align:center; color:#C55A11;">
                                        <t t-esc="bon.total_quantity"/> L
                                    </td>
                                    <td style="border:1px solid #ccc; padding:6px;"/>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- ── RÉSUMÉ ── -->
                        <table style="width:100%; margin-top:15px; border-collapse:collapse;">
                            <tr>
                                <td style="width:33%; padding:6px;">
                                    <strong>الكمية الموزعة :</strong>
                                    <t t-esc="bon.total_quantity"/> L
                                </td>
                                <td style="width:33%; padding:6px;">
                                    <strong>الكمية المتبقية :</strong>
                                    <t t-esc="bon.remaining_stock"/> L
                                </td>
                                <td style="width:33%; padding:6px;">
                                    <strong>مصادق / Validé :</strong>
                                    <t t-if="bon.is_validated">نعم / Oui</t>
                                    <t t-else="">لا / Non</t>
                                </td>
                            </tr>
                        </table>

                        <!-- ── SIGNATURES ── -->
                        <table style="width:100%; margin-top:40px;">
                            <tr>
                                <td style="width:50%; text-align:center;">
                                    <strong>Chauffeur / السائق</strong>
                                    <br/><br/><br/>___________________
                                </td>
                                <td style="width:50%; text-align:center;">
                                    <strong>Responsable / المسؤول</strong>
                                    <br/><br/><br/>___________________
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>