<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ═══ CATÉGORIE ═══ -->
        <record id="module_transport_energy" model="ir.module.category">
            <field name="name">Énergie Transport</field>
            <field name="description">Gestion de l'énergie du transport</field>
            <field name="sequence">10</field>
        </record>

        <!-- ═══ GROUPE 1 : AGENT POMPISTE ═══ -->
        <record id="group_agent_pompiste" model="res.groups">
            <field name="name">Agent Pompiste</field>
            <field name="category_id" ref="module_transport_energy"/>
            <field name="comment">Peut créer et modifier les bons BGI/BGE et bons lubrifiants.</field>
        </record>

        <!-- ═══ GROUPE 2 : RESPONSABLE ÉNERGIE ═══ -->
        <record id="group_responsable_energie" model="res.groups">
            <field name="name">Responsable Énergie</field>
            <field name="category_id" ref="module_transport_energy"/>
            <field name="implied_ids" eval="[(4, ref('group_agent_pompiste'))]"/>
            <field name="comment">Accès complet : validation, jaugeage, rapports, factures.</field>
        </record>

        <!-- ═══ GROUPE 3 : DIRECTEUR ═══ -->
        <record id="group_directeur_energie" model="res.groups">
            <field name="name">Directeur</field>
            <field name="category_id" ref="module_transport_energy"/>
            <field name="implied_ids" eval="[(4, ref('group_responsable_energie'))]"/>
            <field name="comment">Accès total : approbation jaugeage critique, tous les rapports.</field>
        </record>

    </data>
</odoo>